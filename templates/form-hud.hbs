<section id="token-action-hud-form" class="standard-form">
    <section class="standard-form scrollable">
        <div class="form-group slim">
            <label>{{localize "tokenActionHud.form.hud.grid.label"}}</label>
            <div class="form-fields">
                <input type="checkbox" name="grid" {{~#if settings.grid}}checked{{~/if~}}/>
            </div>
            <p class="hint">{{localize "tokenActionHud.form.hud.grid.hint"}}</p>
        </div>
        <fieldset>
            <legend>{{localize "tokenActionHud.reset"}}</legend>
            <div class="form-group">
                <button type="button" id="tah-dialog-reset-actions" data-action="resetActions">
                    <i class="fa-solid fa-arrow-rotate-left"></i>{{localize "tokenActionHud.form.hud.resetActions.button"}}
                </button>
                <p class="hint">{{localize "tokenActionHud.form.hud.resetActions.hint"}}</p>
            </div>
            <div class="form-group">
                <button type="button" id="tah-dialog-reset-layout" data-action="resetLayout">
                    <i class="fa-solid fa-arrow-rotate-left"></i>{{localize "tokenActionHud.settings.resetLayout.label"}}
                </button>
                <p class="hint">{{localize "tokenActionHud.settings.resetLayout.hint"}}</p>
            </div>
        </fieldset>
    </section>
    <footer class="form-footer" data-application-part="footer">
        <button type="submit" class="save-button">
            <i class="fas fa-solid fa-floppy-disk"></i>{{localize "tokenActionHud.saveAndClose"}}
        </button>
    </footer>
</div>
